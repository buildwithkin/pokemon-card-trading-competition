# Supabase — required for M1-B onwards
# Get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Pokemon TCG API — optional but recommended for higher rate limits
# Free key at https://dev.pokemontcg.io/
POKEMONTCG_API_KEY=

# LLM providers — required from Milestone 2 onwards
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Reddit OAuth — required from Milestone 3 for Corpo bot research tool
# Register app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=chaos-arena/0.1 (by /u/your_username)

# Operator gate — required from Milestone 4 for dashboard auth
OPERATOR_EMAIL=

# NextAuth — required from Milestone 4 onwards
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — Milestone 6 (public voting site)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord OAuth — Milestone 6
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Cloudflare Turnstile CAPTCHA — Milestone 6
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Inngest — Milestone 3 onwards
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Simulator — set to "true" to expose the /simulator page. Leave blank or
# "false" on any public deployment: the simulator runs real LLM turns on
# click and burns real API money. Intended for local recording use only.
NEXT_PUBLIC_ENABLE_SIMULATOR=
